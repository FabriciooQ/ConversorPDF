<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.yo.View.MainScene"
      stylesheets="@styles/style.css"
        >

    <top>
        <HBox alignment="CENTER"
            BorderPane.alignment="CENTER"
        >
            <padding>
                <Insets top="40" right="0" bottom="0" left="0"/>
            </padding>
            <Text text = "Conversor de PDF"
                styleClass = "title"/>
        </HBox>
    </top>

    <center>
        <VBox
            alignment="TOP_CENTER"
            BorderPane.alignment="TOP_CENTER"
            maxWidth="800"
            maxHeight="800"
            fillWidth="true"
            spacing="40"
        >
            <padding>
                <Insets top="50" right="30" bottom="50" left="30"/>
            </padding>
            <VBox
                spacing="10"
                fillWidth="true"
            >
                <Label text="Seleccionar PDF"
                    styleClass="label"/>
                <HBox 
                    maxWidth="Infinity"
                    spacing="10"

                >
                    <TextArea fx:id="textAreaPDF" prefWidth="285" prefHeight="20"
                        HBox.hgrow="ALWAYS"/>
                    <Button fx:id="buttonSelectPDF" styleClass="button" onAction="#selectPDF"/>
                </HBox>
            </VBox>

            <VBox
                spacing="10"
                fillWidth="true"
            >
                <Label text="Seleccionar lugar de guardado del excel"
                    styleClass="label"/>
                <HBox 
                    maxWidth="Infinity"
                    spacing="10"
                >
                    <TextArea fx:id="textAreaExcel" prefWidth="285" prefHeight="20"
                        HBox.hgrow="ALWAYS"/>
                    <Button fx:id="buttonSelectExcel" styleClass="button" onAction="#selectExcel"/>
                </HBox>
            </VBox>

            <HBox alignment="CENTER"
                spacing="10"    
            >
                <Label text="Banco:"
                    styleClass="label"/>
                <ComboBox fx:id="bankSelector" onAction="#selectBank" />
                <CheckBox fx:id="buttonClasificar" styleClass="check-box" text="Clasificar" onAction="#checkClasificar"/>
                <Button fx:id="parametrosButton" styleClass="button" text="Parametros" onAction="#parametrosAction"/>
            </HBox>

            <HBox fx:id="hboxConviertiendo"
                visible="false"
                alignment="CENTER">
                <Text fx:id="textoConvirtiendo">Convirtiendo...</Text>
                <Button fx:id="buttonAbrir"
                    visible="false"
                    onAction="#abrirExcel"
                >Abrir</Button>
            </HBox>
            
            <HBox alignment="CENTER">
                <Button fx:id="buttonConvertir" text="Convertir" onAction="#clasificarAction"/>
            </HBox>
        </VBox>
    </center>


    
</BorderPane>