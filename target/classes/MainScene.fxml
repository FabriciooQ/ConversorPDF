<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.app.MainScene"
      alignment="CENTER">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER">
        <Text text = "Conversor de PDF"
            styleClass = "title"/>
    </HBox>

    <VBox>
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>
        <HBox alignment="CENTER">
            <Label text="Seleccionar PDF"
                styleClass="label"/>
            <TextArea fx:id="textAreaPDF" prefWidth="285" prefHeight="20"/>
            <Button fx:id="buttonSelectPDF" styleClass="button" onAction="#selectPDF"/>
        </HBox>
    </VBox>

    <VBox>
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>
        <HBox alignment="CENTER">
            <Label text="Seleccionar lugar de guardado del excel"
                styleClass="label"/>
            <TextArea fx:id="textAreaExcel" prefWidth="285" prefHeight="20"/>
            <Button fx:id="buttonSelectExcel" styleClass="button"/>
        </HBox>
    </VBox>

    <HBox alignment="CENTER">
        <Label text="Seleccionar Banco"
            styleClass="label"/>
        <ChoiceBox fx:id="bankSelector"/>
        <Button fx:id="parametrosButton" styleClass="button"/>
        <CheckBox fx:id="buttonClasificar" styleClass="check-box" />
    </HBox>

    <HBox alignment="CENTER">
        <Text fx:id="textoConvirtiendo"/>
        <Button fx:id="buttonConvertir"/>
    <HBox/>
    
</VBox>